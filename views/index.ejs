<%- include('partials/header') %>

      <h1>Latest Stories</h1>

      <% if (posts.length===0) { %>
            <p>No posts available. Be the first to share your thoughts!</p>
            <a href="/posts/new">Write a Post</a>
            <% } else { %>
                  <div style="display: flex; flex-direction: column; gap: 20px; margin-top: 20px;">
                        <% posts.forEach(post=> { %>
                              <article style="border: 1px solid #ddd; padding: 15px; border-radius: 6px;">
                                    <h2>
                                          <%= post.title %>
                                    </h2>
                                    <p>
                                          <%= post.content %>
                                    </p>

                                    <div style="margin-top: 10px;">
                                          <a href="/posts/<%= post.id %>/edit"
                                                style="color: #3b82f6; text-decoration: none; font-weight: 500;">Edit</a>
                                          |

                                          <form action="/posts/<%= post.id %>/delete" method="POST"
                                                style="display: inline; margin-left: 5px;">
                                                <button type="submit"
                                                      onclick="return confirm('Are you sure you want to delete this post?')"
                                                      style="color: #ef4444; background: none; border: none; padding: 0; cursor: pointer; font-family: inherit; font-size: 1rem; font-weight: 500;">
                                                      Delete
                                                </button>
                                          </form>
                                    </div>
                              </article>
                              <% }) %>
                  </div>
                  <% } %>

                        <%- include('partials/footer') %>