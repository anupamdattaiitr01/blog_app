<%- include('partials/header') %>

      <h1>Latest Stories</h1>

      <% if (posts.length===0) { %>
            <div style="text-align: center; padding: 3rem 0;">
                  <p style="color: var(--text-muted); margin-bottom: 1rem;">No posts available. Be the first to share
                        your thoughts!</p>
                  <a href="/posts/new" class="btn btn-primary">Write a Post</a>
            </div>
            <% } else { %>
                  <div class="posts-grid">
                        <% posts.forEach(post=> { %>
                              <article class="post-card">
                                    <h2>
                                          <%= post.title %>
                                    </h2>
                                    <p>
                                          <%= post.content %>
                                    </p>
                                    <div class="post-actions">
                                          <a href="/posts/<%= post.id %>/edit" class="btn"
                                                style="background-color: #f1f5f9; color: var(--text-main); border: 1px solid var(--border);">Edit</a>
                                          <form action="/posts/<%= post.id %>/delete" method="POST"
                                                style="display: inline;">
                                                <button type="submit" class="btn btn-danger">Delete</button>
                                          </form>
                                    </div>
                              </article>
                              <% }) %>
                  </div>
                  <% } %>

                        <%- include('partials/footer') %>