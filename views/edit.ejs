<%- include('partials/header') %>

      <h1>Edit Post</h1>

      <form action="/posts/<%= post.id %>/update" method="POST"
            style="display: flex; flex-direction: column; gap: 15px; max-width: 600px; margin-top: 20px;">

            <div style="display: flex; flex-direction: column; gap: 5px;">
                  <label for="title" style="font-weight: bold;">Blog Title</label>
                  <input type="text" id="title" name="title" value="<%= post.title %>" required
                        style="padding: 10px; border-radius: 4px; border: 1px solid #ccc; font-size: 1rem;">
            </div>

            <div style="display: flex; flex-direction: column; gap: 5px;">
                  <label for="content" style="font-weight: bold;">Content</label>
                  <textarea id="content" name="content" rows="8" required
                        style="padding: 10px; border-radius: 4px; border: 1px solid #ccc; font-size: 1rem; font-family: inherit;"><%= post.content %></textarea>
            </div>

            <div>
                  <button type="submit"
                        style="background-color: #10b981; color: white; padding: 10px 20px; border: none; border-radius: 4px; font-size: 1rem; cursor: pointer;">Save
                        Changes</button>
                  <a href="/" style="margin-left: 15px; color: #666; text-decoration: none;">Cancel</a>
            </div>
      </form>

      <%- include('partials/footer') %>